<Window x:Class="ChatAppClient.UserProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hồ sơ cá nhân" Height="450" Width="400" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="White">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="4" Background="{TemplateBinding Background}" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,15,0,15">
            <Grid>
                <Ellipse Width="120" Height="120" Stroke="#007ACC" StrokeThickness="3">
                    <Ellipse.Effect>
                        <DropShadowEffect Color="Gray" BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
                    </Ellipse.Effect>
                </Ellipse>

                <Ellipse x:Name="imgAvatar" Width="110" Height="110" Cursor="Hand" MouseLeftButtonDown="btnChangeAvatar_Click">
                    <Ellipse.Fill>
                        <ImageBrush ImageSource="{Binding CurrentAvatar}" Stretch="UniformToFill"/>
                    </Ellipse.Fill>
                </Ellipse>

                <Border Width="30" Height="30" CornerRadius="15" Background="#007ACC" 
                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,5,5" IsHitTestVisible="False">
                    <TextBlock Text="📷" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="14"/>
                </Border>
            </Grid>

            <TextBlock x:Name="txtEmail" Text="đang tải email..." HorizontalAlignment="Center" Foreground="#888888" FontSize="14" Margin="0,12,0,0" FontWeight="SemiBold"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,10">
            <TextBlock Text="Tên hiển thị" Foreground="#666666" FontSize="12" FontWeight="Bold" Margin="5,0,0,5"/>

            <TextBox x:Name="txtDisplayName" 
                     Text="Tên người dùng"
                     Height="40" 
                     FontSize="18" FontWeight="Bold" Foreground="#333333"
                     Background="#F0F2F5" BorderThickness="1" BorderBrush="#DDDDDD"
                     VerticalContentAlignment="Center" Padding="10,0"
                     IsReadOnly="True"/>
        </StackPanel>

        <Button x:Name="btnEdit" Grid.Row="2" Content="Sửa tên" 
                Width="100" Height="30" Background="#007ACC" Foreground="White" FontWeight="Bold"
                HorizontalAlignment="Left" Margin="0,5,0,0"
                Click="btnEdit_Click"/>

        <StackPanel x:Name="pnlActions" Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Collapsed">
            <Button x:Name="btnSave" Content="Lưu thay đổi" 
                    Width="120" Height="40" Background="#42B72A" Foreground="White" FontWeight="Bold" FontSize="14"
                    Margin="0,0,10,0" Click="btnSave_Click"/>

            <Button x:Name="btnCancel" Content="Hủy" 
                    Width="80" Height="40" Background="#E4E6EB" Foreground="Black" FontWeight="Bold" FontSize="14"
                    Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>