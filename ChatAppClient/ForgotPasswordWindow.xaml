<Window x:Class="ChatAppClient.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Khôi phục mật khẩu" Width="380" 
        SizeToContent="Height" 
        WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize">

    <StackPanel Margin="20,20,20,30">
        <TextBlock Text="QUÊN MẬT KHẨU" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,25"/>

        <TextBlock Text="Nhập Email của bạn:" FontWeight="SemiBold"/>
        <TextBox x:Name="txtEmail" Height="32" Margin="0,5,0,15" Padding="5" VerticalContentAlignment="Center"/>
        <Button x:Name="btnSendCode" Content="Gửi mã xác nhận" Height="38" Background="#F0F2F5" Foreground="#333" FontWeight="SemiBold" BorderThickness="1" BorderBrush="#CCC" Click="btnSendCode_Click"/>

        <StackPanel x:Name="pnlReset" Visibility="Collapsed" Margin="0,25,0,0">
            <TextBlock Text="Nhập mã xác nhận (6 số):" FontWeight="SemiBold"/>
            <TextBox x:Name="txtCode" Height="32" Margin="0,5,0,15" Padding="5" VerticalContentAlignment="Center"/>

            <TextBlock Text="Mật khẩu mới:" FontWeight="SemiBold"/>
            <PasswordBox x:Name="txtNewPass" Height="32" Margin="0,5,0,20" Padding="5" VerticalContentAlignment="Center"/>

            <Button x:Name="btnReset" Content="Đổi mật khẩu" Height="40" Background="#28A745" Foreground="White" FontSize="14" FontWeight="Bold" BorderThickness="0" Click="btnReset_Click"/>
        </StackPanel>
    </StackPanel>
</Window>