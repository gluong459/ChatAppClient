<Window x:Class="ChatAppClient.AddFriendWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thêm bạn bè" Height="500" Width="420" ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgMain}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Tìm kiếm bạn mới (Tên, Email hoặc Username)" Grid.Row="0" Padding="10" Foreground="{DynamicResource TextMain}" BorderBrush="{DynamicResource BorderColor}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtSearchUser" Height="30" Padding="5" VerticalContentAlignment="Center" Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextMain}" BorderBrush="{DynamicResource BorderColor}"/>
                <Button Content="Tìm" Grid.Column="1" Margin="5,0,0,0" Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextMain}" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Click="btnSearch_Click"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="Kết quả tìm kiếm" Grid.Row="1" Margin="0,10,0,0" x:Name="pnlResultGroup" Visibility="Collapsed" Foreground="{DynamicResource TextMain}" BorderBrush="{DynamicResource BorderColor}">
            <ListBox x:Name="lstSearchResults" BorderThickness="0" Background="Transparent" MaxHeight="160" ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="350" Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextMain}"/>
                                <TextBlock Text="{Binding Email}" Foreground="#007ACC" FontSize="12" Margin="0,2,0,0"/>
                                <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TextSub}" FontSize="12" Margin="0,2,0,0"/>
                            </StackPanel>

                            <Button Content="{Binding ButtonText}" Grid.Column="1" Width="80" Height="30" VerticalAlignment="Center"
                                    Visibility="{Binding ButtonVisibility}"
                                    Tag="{Binding Id}" Click="btnAction_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#007ACC"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="IsEnabled" Value="{Binding IsButtonEnabled}"/>

                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Background" Value="{DynamicResource BgInput}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSub}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <TextBlock Text="Lời mời kết bạn" Grid.Row="3" FontWeight="Bold" Margin="0,0,0,5" Foreground="{DynamicResource TextMain}"/>

        <ListBox x:Name="lstRequests" Grid.Row="4" BorderBrush="{DynamicResource BorderColor}" Background="Transparent">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Width="350" Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>

                        <Button Content="Đồng ý" Grid.Column="1" Margin="5,0" Padding="10,2" 
                                Background="#42B72A" Foreground="White" FontWeight="Bold" BorderThickness="0" Tag="{Binding Id}" Click="btnAccept_Click"/>

                        <Button Content="Từ chối" Grid.Column="2" Padding="10,2" 
                                Background="#E53935" Foreground="White" FontWeight="Bold" BorderThickness="0" Tag="{Binding Id}" Click="btnDecline_Click"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>