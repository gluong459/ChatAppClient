<Window x:Class="ChatAppClient.CreateGroupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tạo / Tham gia nhóm" Height="500" Width="400" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BgMain}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Tạo nhóm mới" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" Foreground="{DynamicResource TextMain}"/>

        <TextBox x:Name="txtGroupName" Grid.Row="1" Height="30" Padding="5" VerticalContentAlignment="Center" Tag="Nhập tên nhóm (Bỏ trống để tạo tự động)" Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextMain}" BorderBrush="{DynamicResource BorderColor}"/>
        <TextBlock Grid.Row="1" Text="Tên nhóm" Foreground="{DynamicResource TextSub}" Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False" x:Name="lblPlaceholder"/>

        <TextBlock Grid.Row="2" Text="Chọn bạn bè để thêm:" Margin="0,15,0,5" VerticalAlignment="Top" Foreground="{DynamicResource TextMain}"/>
        <ListBox x:Name="lstFriendsToSelect" Grid.Row="2" Margin="0,35,0,10" BorderBrush="{DynamicResource BorderColor}" Background="Transparent">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Name}" Tag="{Binding Id}" Margin="5" Foreground="{DynamicResource TextMain}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Button x:Name="btnCreate" Grid.Row="3" Content="TẠO NHÓM" Height="35" Background="#007ACC" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="btnCreate_Click"/>

        <Separator Grid.Row="4" Margin="0,15" Background="{DynamicResource BorderColor}"/>

        <StackPanel Grid.Row="5">
            <TextBlock Text="Tham gia bằng mã code" FontWeight="Bold" Margin="0,0,0,5" Foreground="{DynamicResource TextMain}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtInviteCode" Height="30" Padding="5" CharacterCasing="Upper" MaxLength="8" Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextMain}" BorderBrush="{DynamicResource BorderColor}"/>
                <Button x:Name="btnJoin" Grid.Column="1" Content="Tham gia" Margin="5,0,0,0" Background="#42B72A" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="btnJoin_Click"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>